# ── CRLX1Q / Space — environment template ──
# Copy this file to .env and fill in real values. Never commit .env.

# Admin panel password
CRLPASS=

# JWT signing secret (use a long random string)
JWT_SECRET=

# MongoDB connection string
MONGO_URI=

# Cloudflare R2 (S3-compatible) storage
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT=
R2_BUCKET=space
R2_PUBLIC_URL=

# Google Gemini API key (used server-side only)
GEMINI_API_KEY=

# Optional: comma-separated model fallback order
GEMINI_MODELS=gemini-2.5-flash-lite-preview-06-17,gemini-2.0-flash-lite,gemini-2.0-flash
